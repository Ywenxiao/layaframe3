{
  "name": "LayaProject1",
  "minifyJS": true,
  "sourcemap": true,
  "alwaysIncluded": [
    "view",
    "cdn"
  ],
  "excludeFilesRule": [],
  "enableVersion": true,
  "enableSubpackages": true,
  "subpackages": [],
  "web": {
    "useSafeFileExtensions": true
  },
  "android": {
    "packResources": false,
    "dcc": {
      "enable": true,
      "generate": true
    },
    "exportProject": true,
    "screenOrientation": "portrait",
    "targetArchitectures": {
      "ARMv7": false,
      "ARM64": true,
      "x86": true,
      "x86-64": false
    },
    "exportFormat": "APK",
    "minSdkVersion": 27
  },
  "wxgame": {
    "appid": "1"
  },
  "harmony": {
    "dcc": {
      "enable": true,
      "generate": true
    },
    "bundleIdentifier": "ohos.test.game"
  }
}