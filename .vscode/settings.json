{
  "files.exclude": {
    "**/.DS_Store": true,
    "**/*.meta": true,
    "library/": true,
    "temp/": true,
    "local/": true
  },
   "[typescript]": {
    // Windsurf 提示延迟显示,给 tsserver 先响应的机会
