{
  "compilerOptions": {
    "lib": [
      "DOM",
      "ES2017"
    ],
    "module": "esnext",
    "target": "es6",
    "strict": false,
    "strictNullChecks": false,
    "noEmitHelpers": true,
    "sourceMap": false,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "~/packages/*": [
        "./library/packages/*"
      ],
      "@SOUND": [
        "./src/platform/sound/LayaSoundAdapter.ts"
      ]
    }
  },
  "include": [
    "./assets",
    "./src",
    "./engine"
  ]
}