{
  "compilerOptions": {
    "module": "es6",
    "target": "es6",
    "strict": false,
    "strictNullChecks": false,
    "noEmitHelpers": true,
    "sourceMap": false,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "~/packages/*": ["./library/packages/*"],
      "@SOUND": ["src/platform/sound/LayaSoundAdapter.ts"]
    }
  },
  "include": ["./assets", "./src", "./engine"]
}
